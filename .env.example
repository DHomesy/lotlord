# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# In production: set to 'false' ONLY if your DB provider uses a self-signed cert that
# your runtime does not trust (e.g. some Railway internal hostnames). Leave unset or
# set to 'true' (the default) for all standard deployments.
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Optional — paste the full PEM certificate from your DB provider when using a
# custom CA bundle (uncommon; only needed if REJECT_UNAUTHORIZED stays true but
# the cert chain is not in the system trust store).
# DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\n...

# Auth
# Generate both secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
# Separate secret for refresh tokens. If unset, falls back to JWT_SECRET + '_refresh'.
# Setting a truly independent value means a compromised access-token secret cannot be
# used to forge refresh tokens (and vice-versa). Strongly recommended in production.
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret
JWT_EXPIRES_IN=15m           # access token lifetime  (short — stored in memory on client)
JWT_REFRESH_EXPIRES_IN=30d   # refresh token lifetime (long  — httpOnly cookie only)

# Frontend
# Used for CORS allowed-origin. Comma-separate multiple origins in production.
FRONTEND_URL=http://localhost:5173

# AWS SES — email sending + inbound processing
# IAM credentials are output by the CDK stack (cdk deploy) as ApiSesAccessKeyId / ApiSesSecretAccessKey
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Sender addresses — must match verified SES domain (lotlord.app)
SES_FROM_ADDRESS=noreply@lotlord.app
SES_REPLY_TO_ADDRESS=reply@lotlord.app

# SES configuration set — routes bounce/complaint events to SNS (created by CDK)
SES_CONFIGURATION_SET=lotlord-config-set

# Shared secret — Lambda authenticates to POST /api/v1/webhooks/ses with this header
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the webhookSecret passed to `cdk deploy --context webhookSecret=<value>`
SES_WEBHOOK_SECRET=

# AWS S3 — file storage (documents + maintenance attachments)
S3_BUCKET_NAME=lotlord-files

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Public URL of this server — used to verify Twilio webhook signatures
# Use your Railway/production URL in production; set to your ngrok URL for local testing
APP_BASE_URL=https://your-app.railway.app

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Pro plan Price ID — create in Stripe Dashboard → Products → Add Product → Monthly
STRIPE_PRICE_ID=price_...

# OpenAI
OPENAI_API_KEY=sk-...

# Error alerting — SES email sent on any 5xx or unhandled rejection (production only)
ALERT_EMAIL=

# --- Future / Uncomment when scaling ---
# REDIS_URL=redis://localhost:6379
