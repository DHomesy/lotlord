# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=15m           # access token lifetime (short — kept in memory)
JWT_REFRESH_EXPIRES_IN=30d   # refresh token lifetime (long — httpOnly cookie)

# Frontend
# Used for CORS allowed-origin. Comma-separate multiple origins in production.
FRONTEND_URL=http://localhost:5173

# AWS SES — email sending + inbound processing
# IAM credentials are output by the CDK stack (cdk deploy) as ApiSesAccessKeyId / ApiSesSecretAccessKey
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Sender addresses — must match verified SES domain (lotlord.app)
SES_FROM_ADDRESS=noreply@lotlord.app
SES_REPLY_TO_ADDRESS=reply@lotlord.app

# SES configuration set — routes bounce/complaint events to SNS (created by CDK)
SES_CONFIGURATION_SET=lotlord-config-set

# Shared secret — Lambda authenticates to POST /api/v1/webhooks/ses with this header
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the webhookSecret passed to `cdk deploy --context webhookSecret=<value>`
SES_WEBHOOK_SECRET=

# Google Drive API — same OAuth2 app as Gmail
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Public URL of this server — used to verify Twilio webhook signatures
# Use your Railway/production URL in production; set to your ngrok URL for local testing
APP_BASE_URL=https://your-app.railway.app

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI
OPENAI_API_KEY=sk-...

# --- Future / Uncomment when scaling ---
# REDIS_URL=redis://localhost:6379
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SES_REGION=us-east-1
# AWS_S3_BUCKET=
# AWS_S3_REGION=us-east-1
