{
  "name": "property-manager",
  "version": "1.5.14",
  "description": "Full-stack property management platform — API server",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev:api": "nodemon src/index.js",
    "dev:web": "cd frontend && npm run dev",
    "dev": "npm run dev:api & npm run dev:web",
    "migrate:up": "node src/config/migrate.js",
    "seed": "node seeds/dev_seed.js",
    "create-admin": "node scripts/create-admin.js",
    "update-admin": "node scripts/update-admin.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/client-ses": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "googleapis": "^140.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "openai": "^4.28.0",
    "pg": "^8.11.3",
    "stripe": "^14.21.0",
    "twilio": "^5.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": ["dotenv/config"],
    "globalSetup": "./tests/helpers/globalSetup.js"
  }
}
